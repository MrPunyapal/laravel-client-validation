{
  "name": "laravel-client-validation",
  "version": "2.0.0",
  "description": "Laravel validation rules for client-side JavaScript. Works with Alpine.js, Vanilla JS, Livewire, React, Vue, or any framework.",
  "main": "resources/js/dist/client-validation.umd.js",
  "module": "resources/js/dist/client-validation.es.js",
  "types": "resources/js/index.d.ts",
  "exports": {
    ".": {
      "import": "./resources/js/index.js",
      "require": "./resources/js/dist/client-validation.umd.js"
    },
    "./core": {
      "import": "./resources/js/core/index.js"
    },
    "./alpine": {
      "import": "./resources/js/adapters/alpine.js"
    },
    "./vanilla": {
      "import": "./resources/js/adapters/vanilla.js"
    },
    "./livewire": {
      "import": "./resources/js/adapters/livewire.js"
    },
    "./react": {
      "import": "./resources/js/adapters/react.js"
    },
    "./vue": {
      "import": "./resources/js/adapters/vue.js"
    }
  },
  "files": [
    "resources/js/core/",
    "resources/js/adapters/",
    "resources/js/dist/",
    "resources/js/index.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-bundle.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint resources/js --ext .js",
    "lint:fix": "eslint resources/js --ext .js --fix",
    "format": "prettier --write resources/js/**/*.js",
    "prepublishOnly": "npm run build && npm test -- --run"
  },
  "keywords": [
    "laravel",
    "validation",
    "alpine.js",
    "livewire",
    "filament",
    "javascript",
    "client-side",
    "form-validation",
    "vue",
    "react",
    "vanilla-js"
  ],
  "author": "Punyapal Shah <mrpunyapal@gmail.com>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrpunyapal/laravel-client-validation.git"
  },
  "homepage": "https://github.com/mrpunyapal/laravel-client-validation#readme",
  "bugs": {
    "url": "https://github.com/mrpunyapal/laravel-client-validation/issues"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "alpinejs": {
      "optional": true
    }
  },
  "sideEffects": [
    "./resources/js/index.js"
  ]
}
